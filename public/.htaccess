# /admin a /admin/ -> admin.html (mod_alias, funguje i když mod_rewrite ne)
<IfModule mod_alias.c>
  RedirectMatch 302 ^/admin/?$ /admin.html
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^admin/?$ admin.html [L]
  RewriteRule ^jj-backstage/?$ jj-backstage/index.html [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(ico|png|jpg|jpeg|webp|gif|svg|woff2?|ttf|eot|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
