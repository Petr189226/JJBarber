{
  "name": "jj-barbershop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "clean:dist": "node -e \"import('fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy-forpsi": "node scripts/check-env.mjs && npm run build && node scripts/zip-for-forpsi.mjs",
    "deploy-websupport": "node scripts/check-env.mjs && npm run clean:dist && npm run build && node scripts/zip-for-websupport.mjs",
    "supabase:setup": "node scripts/supabase-setup.mjs",
    "supabase:setup-roles": "node scripts/supabase-setup-roles.mjs",
    "supabase:setup-roles-003": "node scripts/supabase-setup-roles-003.mjs"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
